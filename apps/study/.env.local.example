# Shared with the Family app's Supabase project. The anon key is public-safe (RLS
# protects data). Copy real values from apps/family/.env.local for local dev.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed to run scripts/seed.mjs (bypasses RLS to upsert study_docs).
# Find it in Supabase → Project Settings → API → service_role. NEVER commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
