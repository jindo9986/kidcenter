{
  "name": "kidcenter",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of independent web apps for my kids — learning activity & daily-schedule manager and a kid portfolio for program applications.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "dev:learning": "pnpm --filter @kidcenter/learning dev",
    "dev:portfolio": "pnpm --filter @kidcenter/portfolio dev",
    "dev:family": "pnpm --filter @kidcenter/family dev",
    "dev:study": "pnpm --filter @kidcenter/study dev"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  },
  "engines": {
    "node": ">=20"
  }
}
